<?xml version="1.0" encoding="utf-8"?>
<!--
  Silver / metallic progress fill for the splash ProgressBar.
  Same structure as progress_fill.xml but with a chrome-like gradient
  (light silver → white → light silver) instead of the green-blue shimmer.
  Use in ProgressBar as android:progressDrawable="@drawable/progress_silver".
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Track -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="3dp" />
            <solid android:color="#1AFFFFFF" />
            <stroke
                android:width="0.5dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>

    <!-- Fill -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="3dp" />
                <gradient
                    android:angle="270"
                    android:startColor="#B0B7C3"
                    android:centerColor="#F5F7FA"
                    android:endColor="#8892A0"
                    android:type="linear" />
            </shape>
        </clip>
    </item>

    <!-- Secondary highlight sheen (optional gloss on top) -->
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="3dp" />
                <gradient
                    android:angle="90"
                    android:startColor="#40FFFFFF"
                    android:endColor="#00FFFFFF"
                    android:type="linear" />
            </shape>
        </clip>
    </item>

</layer-list>
