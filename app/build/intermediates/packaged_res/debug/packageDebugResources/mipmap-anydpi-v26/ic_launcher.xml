<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon (API 26+). The OS composites background + foreground
  and masks them into whatever shape the launcher uses (circle,
  squircle, rounded square, teardrop, etc). Background fills the full
  canvas edge-to-edge with the brand gradient, so no white shows
  through regardless of the mask shape the launcher applies.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@mipmap/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
