<?xml version="1.0" encoding="utf-8"?>
<!--
  Scanning-line drawable used on the splash to hint "loading / initializing".
  Horizontal gradient that fades from transparent → bright cyan/white → transparent.
  Combine with a translate animation to make it slide across the sphere.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <size
        android:width="200dp"
        android:height="2dp" />
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#0022c55e"
        android:centerColor="#CC4ade80"
        android:endColor="#0022c55e" />
</shape>
